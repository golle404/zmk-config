/*
 * Test keymap for verifying all keys and encoders work.
 * Single layer — every key outputs a visible keycode.
 * Encoders: left = UP/DOWN arrows, right = LEFT/RIGHT arrows.
 *
 * To use: rename this to sofle.keymap (back up the original first).
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        test_layer {
            display-name = "test";
// ---------------------------------------------------------------------------------------------------------------
// |   `   |  1  |  2  |  3  |  4  |  5  |                   |  6  |  7  |  8  |  9  |  0  |  -  |
// |   A   |  q  |  w  |  e  |  r  |  t  |                   |  y  |  u  |  i  |  o  |  p  |  B  |
// |   C   |  a  |  s  |  d  |  f  |  g  |                   |  h  |  j  |  k  |  l  |  ;  |  '  |
// |   D   |  z  |  x  |  c  |  v  |  b  | ENC_L |  | ENC_R |  n  |  m  |  ,  |  .  |  /  |  =  |
//               |  E  |  F  |  G  |  H  |   I   |  |   J   |  K  |  L  |  M  |  N  |
            bindings = <
&kp GRAVE    &kp N1 &kp N2 &kp N3   &kp N4   &kp N5                          &kp N6 &kp N7   &kp N8    &kp N9  &kp N0   &kp MINUS
&kp LS(A)    &kp Q  &kp W  &kp E    &kp R    &kp T                           &kp Y  &kp U    &kp I     &kp O   &kp P    &kp LS(B)
&kp LS(C)    &kp A  &kp S  &kp D    &kp F    &kp G                           &kp H  &kp J    &kp K     &kp L   &kp SEMI &kp SQT
&kp LS(D)    &kp Z  &kp X  &kp C    &kp V    &kp B  &kp F13    &kp F14      &kp N  &kp M    &kp COMMA &kp DOT &kp FSLH &kp EQUAL
                    &kp LS(E) &kp LS(F) &kp LS(G) &kp LS(H) &kp LS(I)  &kp LS(J) &kp LS(K) &kp LS(L) &kp LS(M) &kp LS(N)
            >;

            // Left encoder: UP/DOWN — Right encoder: LEFT/RIGHT
            sensor-bindings = <&inc_dec_kp UP DOWN &inc_dec_kp RIGHT LEFT>;
        };
    };
};
